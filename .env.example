# =============================================================================
# SHARED
# =============================================================================
NODE_ENV=development

# =============================================================================
# SUPABASE
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# =============================================================================
# ANTHROPIC
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# OPENAI (embeddings via text-embedding-3-small)
# =============================================================================
OPENAI_API_KEY=sk-...

# =============================================================================
# TRADINGVIEW
# =============================================================================
TRADINGVIEW_COOKIE=your-tradingview-cookie

# =============================================================================
# STRIPE
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# =============================================================================
# RESEND (email notifications)
# =============================================================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# API (FastAPI)
# =============================================================================
API_URL=http://localhost:8000
API_SECRET_KEY=change-this-long-random-secret
ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# NEXT.JS
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# TOKEN LIMITS (defaults, can be overridden per user in DB)
# =============================================================================
DEFAULT_MONTHLY_TOKEN_BUDGET=1000000
MAX_TICKERS_PER_SCAN=20
MIN_SCAN_INTERVAL_MINUTES=15
